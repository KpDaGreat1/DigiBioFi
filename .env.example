# ─────────────────────────────────────────────────────────
# DigiBioFi — Environment Variables
# Copy to .env and fill in all values before running.
# ─────────────────────────────────────────────────────────

# App
APP_NAME="DigiBioFi"
APP_ENV=development          # development | production
DEBUG=true
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_LONG_RANDOM_VALUE_AT_LEAST_32_CHARS
# REQUIRED FOR PRODUCTION: set to your public VPS URL (no trailing slash)
BASE_URL=http://localhost:8000

# Security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CSRF_SECRET_KEY=change-me-to-a-random-csrf-secret

# Database
# Local dev (SQLite — auto-created, no setup needed):
DATABASE_URL=sqlite:///./digibiofi.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@host:5432/digibiofi

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# File uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# Admin bootstrap
# REQUIRED: Must be set via environment variable — never commit real credentials
ADMIN_EMAIL=admin@example.com
# REQUIRED — must be set; startup will fail if missing or under 8 chars
ADMIN_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# Stripe (required for billing features)
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Get Price IDs from https://dashboard.stripe.com/products
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PREMIUM=price_...
# Preferred name for the elite plan price (legacy STRIPE_PRICE_PREMIUM is still supported)
STRIPE_PRICE_ELITE=price_...

# Email (scaffold — not required for MVP local dev)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@example.com
EMAILS_FROM_NAME="DigiBioFi"

# CORS (comma-separated — include your VPS domain in production)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
# Production example:
# ALLOWED_ORIGINS=https://yourdomain.com
