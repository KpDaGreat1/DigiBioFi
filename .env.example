# DigiBioFi — environment template
# Copy to .env and set real values before deploying.

# App
APP_NAME="DigiBioFi"
APP_ENV=development
DEBUG=true
BASE_URL=http://localhost:8000

# Security
SECRET_KEY=replace-with-a-unique-64-character-secret
CSRF_SECRET_KEY=replace-with-a-different-64-character-secret
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_SECONDS=60

# Database
DATABASE_URL=sqlite:///./digibiofi.db
REDIS_URL=redis://localhost:6379/0

# Docker Compose PostgreSQL
POSTGRES_USER=digibiofi_user
POSTGRES_PASSWORD=replace-with-postgres-password
POSTGRES_DB=digibiofi_db

# JWT / auth
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_RESET_EXPIRE_MINUTES=30
EMAIL_VERIFICATION_EXPIRE_HOURS=24

# File uploads / limits
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5
FREE_DAILY_PROFILE_VIEW_LIMIT=25

# Admin bootstrap
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=ChangeMe123!

# Stripe (optional unless billing is enabled)
STRIPE_SECRET_KEY=sk_live_or_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_BASIC=price_basic_replace_me
STRIPE_PRICE_ELITE=price_elite_replace_me

# Google AdSense (optional)
ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
ADSENSE_PUBLIC_INLINE_SLOT=0000000000
ADSENSE_PUBLIC_SIDEBAR_SLOT=0000000000
ADSENSE_DASHBOARD_SLOT=0000000000

# Email / messaging (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@example.com
EMAILS_FROM_NAME="DigiBioFi"

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
