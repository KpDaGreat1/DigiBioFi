# DigiBioFi — environment template
# Copy to .env and set real values before deploying.
# ⚠️  NEVER commit real secrets to this file or to version control.

# App
APP_NAME="DigiBioFi"
APP_ENV=development
DEBUG=true
BASE_URL=http://localhost:8000

# Security — GENERATE UNIQUE VALUES FOR PRODUCTION
# Use: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-ME-generate-a-64-char-hex-string-with-secrets-token-hex
CSRF_SECRET_KEY=CHANGE-ME-generate-a-64-char-hex-string-with-secrets-token-hex
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_SECONDS=60

# Database
DATABASE_URL=sqlite:///./digibiofi.db
REDIS_URL=redis://localhost:6379/0

# Docker Compose PostgreSQL
POSTGRES_USER=digibiofi_user
POSTGRES_PASSWORD=CHANGE-ME
POSTGRES_DB=digibiofi_db

# JWT / auth
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_RESET_EXPIRE_MINUTES=30
EMAIL_VERIFICATION_EXPIRE_HOURS=24

# File uploads / limits
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5
FREE_DAILY_PROFILE_VIEW_LIMIT=25

# Admin bootstrap — SET STRONG CREDENTIALS
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE-ME-at-least-8-chars

# Stripe (leave empty to disable billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_ELITE=

# Google AdSense (leave empty to disable ads)
ADSENSE_CLIENT_ID=
ADSENSE_PUBLIC_INLINE_SLOT=
ADSENSE_PUBLIC_SIDEBAR_SLOT=
ADSENSE_DASHBOARD_SLOT=

# Email — SendGrid SMTP
# SMTP_USER must be the literal string "apikey" for SendGrid
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@example.com
EMAILS_FROM_NAME="DigiBioFi"
SMTP_TLS=true
SMTP_SSL=false

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
